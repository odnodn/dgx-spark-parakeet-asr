# =============================================================================
# Environment variables for the Voice Agent stack
# Copy this to .env and fill in your values
# In Portainer: add these under Stack > Environment variables
# =============================================================================

# Your NGC API key GET-YOUR-API-KEY-AND-PASTE-IT-HERE - https://build.nvidia.com/nvidia/parakeet-tdt-0_6b-v2
# Get one at: https://org.ngc.nvidia.com/setup/api-key
NGC_API_KEY=nvapi-REPLACE_WITH_YOUR_ACTUAL_KEY

# Optional: HuggingFace token (only needed if model is gated)
# HF_TOKEN=hf_xxxxx

# ── Realtime Streaming (Riva/NIM WebSocket ASR) ──────────────────────────────
# WebSocket URL of your Riva or NIM ASR service
# RIVA_ASR_URL=ws://localhost:50051/asr/ws

# API key for NIM cloud endpoints (optional, leave empty for on-premise Riva)
# RIVA_API_KEY=

# Default language for streaming (BCP-47 code)
# RIVA_LANGUAGE=en-US
